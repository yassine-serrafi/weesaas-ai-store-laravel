APP_NAME=WeeSaaS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wesaas
DB_USERNAME=root
DB_PASSWORD=

# Ancienne base WeeSaaS (pour l'import unique des données prod via artisan)
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=shupaz
LEGACY_DB_USERNAME=root
LEGACY_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Doit dépasser le timeout du job GenerateProductPage (1800s) pour éviter
# qu'un job IA long soit redéclenché et génère le produit en double.
DB_QUEUE_RETRY_AFTER=2000
# Worker auto : un clic sur « Générer » lance un worker en arrière-plan (pas de queue:work manuel).
WEESAAS_AUTO_WORKER=true
# Chemin du php.exe CLI (indispensable sous Apache où PHP_BINARY pointe ailleurs).
# Adapter à votre serveur (ex. /usr/bin/php sous Linux). Laisser commenté pour utiliser le PHP par défaut.
# WEESAAS_PHP_BINARY='C:\xampp3\php\php.exe'

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── WeeSaaS (legacy compat + intégrations) ───────────────────────────────────
# Clé servant à déchiffrer/chiffrer les valeurs sensibles de la table `settings`.
# ⚠️ À REMPLACER par une chaîne aléatoire de 32 caractères en production.
WEESAAS_LEGACY_ENCRYPTION_KEY="change_this_secret_key_in_production_32chars!!"

# Devise / langue par défaut de la boutique (surchargées par la table settings)
WEESAAS_DEFAULT_LANG=fr

# Intégrations IA — laisser VIDE ici : les clés se saisissent dans /weeadmin → Réglages
# (stockées chiffrées en base). Ces variables ne servent que de repli optionnel.
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models/
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/
